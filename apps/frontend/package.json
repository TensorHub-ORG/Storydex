{
  "name": "storydex-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit --skipLibCheck && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "npm run test:unit && npm run test:regressions",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:icon-font": "node --test tests/iconFont.regression.mjs",
    "test:regressions": "node --test tests/*.regression.mjs"
  },
  "dependencies": {
    "@fontsource/material-symbols-rounded": "^5.2.41",
    "axios": "^1.7.9",
    "markdown-it": "^14.1.1",
    "pinia": "^2.2.6",
    "vue": "^3.5.0",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^5.1.4",
    "happy-dom": "^15.11.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.1.8"
  }
}
