API_HOST=127.0.0.1
API_PORT=18081
SERVE_FRONTEND_STATIC=false
FRONTEND_DIST_DIR=C:/path/to/Storydex/apps/frontend/dist
WORKSPACE_ROOT=C:/Users/<YourUser>/.storydex/workspace
STORYDEX_DIR_NAME=.storydex
STORYDEX_GLOBAL_ROOT=C:/Users/<YourUser>/.storydex

# Optional account/quota service targets. Leave empty for local-only development.
STORYKEEPER_BASE_URL=
QUOTA_GATEWAY_BASE_URL=
# Legacy server-to-server shared token. Leave empty for desktop user-session mode.
STORYKEEPER_INTERNAL_TOKEN=

# Coomi reads model/provider settings from:
# C:/Users/<YourUser>/.storydex/.coomi/config/providers.json

