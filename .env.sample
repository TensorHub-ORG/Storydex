# Storydex root environment template

# Optional database connection (if your local flow needs DB features)
NOVEL_DATABASE_URL=postgresql+psycopg://user:password@127.0.0.1:5432/storydex?connect_timeout=15

# Desktop account-system proxy target.
# Packaged desktop builds default to https://storykeeper.septemc.cn, so this is only needed for overrides.
STORYKEEPER_BASE_URL=https://storykeeper.septemc.cn
# Hosted quota gateway used by the managed `account-quota` profile.
QUOTA_GATEWAY_BASE_URL=https://api.septemc.cn
# Legacy server-to-server shared token. Desktop user auth no longer requires this on user machines.
STORYKEEPER_INTERNAL_TOKEN=

# LLM provider settings
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=MiniMax-M2.7

# Optional backend runtime overrides
API_HOST=127.0.0.1
API_PORT=18081
SERVE_FRONTEND_STATIC=false
FRONTEND_DIST_DIR=C:/path/to/Storydex/apps/frontend/dist
WORKSPACE_ROOT=C:/Users/your_name/.storydex/workspace
STORYDEX_DIR_NAME=.storydex

LLM_PROVIDER=anthropic_messages
LLM_TIMEOUT_SECONDS=180
LLM_TEMPERATURE=0.8
LLM_PLANNER_MAX_TOKENS=2500
LLM_STAGE1_MAX_TOKENS=6000
LLM_STAGE2_MAX_TOKENS=5000
LLM_REASONING_MODE_DEFAULT=high
LLM_MOCK_ENABLED=false

STAGE1_MIN_WORDS=900
STAGE2_EVENT_ENABLED=false

# Embedding API for semantic search (optional, BM25 works without these)
# When configured, hybrid_search combines BM25 + semantic vector retrieval.
# Supports any OpenAI-compatible /v1/embeddings endpoint.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-v3
